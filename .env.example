# Application
APP_NAME=UniversalAI
ENV=development
APP_DEBUG=false
API_PREFIX=/api
ALLOWED_ORIGINS=["http://localhost:5500","http://127.0.0.1:5500"]

# ⚠️ REQUIRED for API key encryption — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_KEY=

# Storage
MAX_UPLOAD_SIZE_MB=25

# Cloud providers (add only the keys you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_NIM_API_KEY=
TOGETHER_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Provider and local-runtime endpoints
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234/v1
VLLM_BASE_URL=http://localhost:8001/v1
